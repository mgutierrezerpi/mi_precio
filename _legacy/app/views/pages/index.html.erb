<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        <%= @current_tenant.name %>
      </h1>
      <% if @list_version %>
        <p class="text-gray-600 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          <%= @list.name %> - <%= @list_version.name %>
        </p>
      <% else %>
        <p class="text-gray-600 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          Browse our menu and price list below
        </p>
      <% end %>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto pt-8 px-4 sm:px-6 lg:px-8 py-10">

    <% if @items.any? %>
      <!-- Display Real Items from Database -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-8 bg-blue-500 rounded"></div>
          <h2 class="text-3xl font-bold text-gray-900"><%= @list.name %></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @items.each do |item| %>
            <div class="bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <% if item.picture.attached? %>
                <div class="aspect-w-16 aspect-h-9 bg-gray-200">
                  <%= image_tag item.picture, class: "w-full h-48 object-cover" %>
                </div>
              <% end %>

              <div class="p-6">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-xl font-semibold text-gray-900"><%= item.name %></h3>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-lg font-bold text-blue-700 bg-blue-100 ml-2 whitespace-nowrap">
                    $<%= number_with_precision(item.price, precision: 2) %>
                  </span>
                </div>

                <% if item.description.present? %>
                  <p class="text-gray-600 text-sm">
                    <%= item.description %>
                  </p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    <% else %>
      <!-- Empty State / Sample Menu -->

