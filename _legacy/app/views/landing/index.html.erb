                              </div>
                              <img src="https://cdn.prod.website-files.com/68011fed23249a9699d7b42b/6802fc54afb8dcd46830bebd_pinkish.avif" loading="lazy" alt="" class="stats_texture is-overlay-40">
                           </div>
                           <div class="stats_item background-color-lightblue">
                              <div class="margin-bottom margin-large">
