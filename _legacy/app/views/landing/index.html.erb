<div class="page-wrapper">
   <!-- Phosphor regular icons -->
   <%= stylesheet_link_tag "https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css", "data-turbo-track": "reload" %>
   <!-- Landing page specific styles -->
   <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
   
   <!-- GSAP Libraries -->
   <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
   <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
   <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/Draggable.min.js"></script>
   <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/TextPlugin.min.js"></script>
   
   <!-- Stub for premium GSAP plugins -->
   <script>
   // Create stubs for premium plugins to prevent errors
   if (typeof InertiaPlugin === 'undefined') window.InertiaPlugin = {};
   if (typeof ScrambleTextPlugin === 'undefined') {
     window.ScrambleTextPlugin = {
       version: "3.12.2",
       name: "scrambleText"
     };
     gsap.registerPlugin({
       name: "scrambleText",
       init: function(target, value, tween) {
         this.target = target;
         this.originalText = target.textContent;
         this.scrambleText = value.text || this.originalText;
         this.chars = value.chars || "0123456789";
         this.revealDelay = value.revealDelay || 0.5;
         this.duration = tween.duration();
         return true;
       },
       render: function(ratio) {
         if (ratio >= this.revealDelay) {
           this.target.textContent = this.scrambleText;
         } else {
           let scrambled = "";
           for (let i = 0; i < this.scrambleText.length; i++) {
             scrambled += this.chars[Math.floor(Math.random() * this.chars.length)];
           }
           this.target.textContent = scrambled;
         }
       }
     });
   }
   if (typeof SplitText === 'undefined') {
     window.SplitText = function(target, vars) {
       this.elements = [];
       this.chars = [];
       this.words = [];
       this.lines = [];
       
       const element = typeof target === "string" ? document.querySelector(target) : target;
       if (element) {
         const text = element.textContent;
         element.innerHTML = "";
         
         // Simple character split
         for (let i = 0; i < text.length; i++) {
           const span = document.createElement("span");
           span.textContent = text[i];
           span.style.display = "inline-block";
           element.appendChild(span);
           this.chars.push(span);
         }
       }
     };
   }
   </script>
   
   <!-- Landing page JavaScript -->
   <%= javascript_include_tag "landing", "data-turbo-track": "reload" %>
   </div>
   <!-- Hybrid Navigation: Original desktop styling with improved mobile -->
   <div data-animation="default" class="navbar_component w-nav" data-easing2="ease" fs-scrolldisable-element="smart-nav" data-easing="ease" data-collapse="medium" data-navbar-id="navbar-component" role="banner" data-duration="400">
      <div class="navbar_container">
         <a href="#" class="navbar_logo-link w-nav-brand">
            <div class="navbar_logo"><%= t('landing.hero.title_1') %><%= t('landing.hero.title_2') %></div>
         </a>
         
         <!-- Desktop Menu with original styling -->
         <nav role="navigation" class="navbar_menu is-page-height-tablet w-nav-menu hidden md:flex">
            <div class="navbar_menu-links">
               <a href="#mission" class="navbar_link w-nav-link"><%= t('landing.approach.title') %></a>
               <a href="#stats" class="navbar_link w-nav-link"><%= t('landing.restaurants.title') %></a>
            </div>
            <div class="navbar_menu-buttons">
               <a data-button-variant="full-red" href="#footer" class="btn w-inline-block">
                  <div><%= t('landing.restaurants.get_started') %></div>
               </a>
            </div>
         </nav>
         
         <!-- Mobile menu button - styled better -->
         <button id="mobile-menu-button" class="navbar_menu-button md:hidden" aria-label="menu">
            <div class="menu-icon1">
               <div class="menu-icon1_line-top"></div>
               <div class="menu-icon1_line-middle">
                  <div class="menu-icon1_line-middle-inner"></div>
               </div>
               <div class="menu-icon1_line-bottom"></div>
            </div>
         </button>
      </div>
      
      <!-- Mobile Menu - better styled -->
      <div id="mobile-menu" class="hidden md:hidden navbar_mobile-menu">
         <div class="navbar_mobile-menu-content">
            <a href="#mission" class="navbar_mobile-link">
               <%= t('landing.approach.title') %>
            </a>
            <a href="#stats" class="navbar_mobile-link">
               <%= t('landing.restaurants.title') %>
            </a>
            <div class="navbar_mobile-buttons">
               <a href="#footer" class="btn w-inline-block" data-button-variant="full-red">
                  <div><%= t('landing.restaurants.get_started') %></div>
               </a>
            </div>
         </div>
      </div>
   </div>
