                        <div class="_2col_grid z-index-2">
                           <h1 class="hero-title" aria-label="<%= t('landing.hero.title_1') %><%= t('landing.hero.title_2') %>"><%= t('landing.hero.title_1') %><%= t('landing.hero.title_2') %></h1>
                           <p class="text-size-medium text-weight-semibold"><%= t('landing.hero.subtitle') %></p>
                        </div>
                     </div>
                  </div>
                  <div class="hero_visuals" style="translate: none; rotate: none; scale: none; opacity: 1; transform: translate(0px, 0px);">
                     <%= image_tag "price_tag.jpg", loading: "lazy", alt: "Digital menu and price tag for modern restaurants", class: "hero_img" %>
                     <div class="noise is-hero"></div>
                     <div class="dark_gradient"></div>
                  </div>
               </div>
            </div>
         </div>
      </header>
      
      <!-- Spacer section for visual breathing room -->
      <div class="py-4"></div>
      
