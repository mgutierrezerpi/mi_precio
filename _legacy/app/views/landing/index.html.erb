      <section id="stats" class="section_stats">
         <div class="padding-global">
            <div class="container-large">
               <div class="padding-section-large">
                  <div class="stats_component">
                     <div class="margin-bottom margin-xxlarge">
                        <div class="text-align-center">
                           <h2><%= t('landing.results.title') %></h2>
                        </div>
                     </div>
                     <div class="w-layout-grid stats_list">
                        <% if @tenants.present? %>
                           <% colors = ['background-color-purple', 'background-color-vermillion', 'background-color-lightblue', 'background-color-orange'] %>
                           <% @tenants.each_with_index do |tenant, index| %>
                              <%
                                if Rails.env.development?
                                  tenant_url = "http://#{tenant.subdomain}.localhost:3000"
                                  tenant_display = "#{tenant.subdomain}.localhost:3000"
                                else
                                  tenant_url = "https://#{tenant.subdomain}.miprecio.uy"
                                  tenant_display = "#{tenant.subdomain}.miprecio.uy"
                                end
                              %>
                              <a href="<%= tenant_url %>" target="_blank" class="stats_item <%= colors[index % colors.length] %>" style="text-decoration: none; cursor: pointer; transition: transform 0.2s;">
                                 <div class="margin-bottom margin-large">
                                    <h3 class="heading-style-h5"><%= tenant.name %></h3>
                                 </div>
                                 <div class="stats_item-content">
                                    <div class="text-size-small" style="opacity: 0.9;">
                                       <%= tenant_display %> →
                                    </div>
                                 </div>
                                 <img src="https://cdn.prod.website-files.com/68011fed23249a9699d7b42b/6802fc54afb8dcd46830bebd_pinkish.avif" loading="lazy" alt="" class="stats_texture is-overlay-40">
                              </a>
                           <% end %>
                        <% else %>
                           <div class="stats_item background-color-purple">
