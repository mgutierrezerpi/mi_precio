<div class="mb-8">
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <nav class="flex mb-3" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1">
          <li class="inline-flex items-center">
            <%= link_to "Lists", admin_lists_path, class: "text-gray-500 hover:text-gray-700" %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 text-gray-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700"><%= @list.name %></span>
            </div>
          </li>
        </ol>
      </nav>
      <h2 class="text-3xl font-bold text-gray-900"><%= @list.name %></h2>
      <div class="mt-2 flex items-center space-x-2">
        <% if @list.published %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            Published
          </span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
            Draft
          </span>
        <% end %>
        <% if @list.show_on_index %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            Shown on Index
          </span>
        <% end %>
      </div>
    </div>
    <div class="mt-4 sm:mt-0 flex space-x-2">
      <%= link_to "Edit", edit_admin_list_path(@list), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    </div>
  </div>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-lg font-medium text-gray-900">Versions</h3>
  </div>
  <ul class="divide-y divide-gray-200">
    <% if @versions.any? %>
      <% @versions.each do |version| %>
        <li class="px-6 py-4">
          <div class="flex items-center justify-between">
            <div>
              <h4 class="text-sm font-medium text-gray-900"><%= version.name %></h4>
              <p class="text-sm text-gray-500">
                Version #<%= version.version_number %> • <%= version.items.count %> items
                <% if version.published %>
                  <span class="ml-2 text-green-600">• Currently Published</span>
                <% end %>
              </p>
            </div>
            <div class="flex items-center space-x-2">
              <%= link_to "View Items", admin_list_version_items_path(@list, version), class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
              <% unless version.published %>
                <%= button_to "Publish", publish_admin_list_version_path(@list, version), method: :post, class: "inline-flex items-center px-3 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    <% else %>
      <li class="px-6 py-4 text-center text-gray-500">
        No versions yet. Create your first version!
      </li>
    <% end %>
  </ul>
</div>
