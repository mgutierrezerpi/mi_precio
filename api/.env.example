# Application
APP_NAME="Mi Precio API"
DEBUG=true

# Database
DATABASE_PATH=db/mi_precio.db

# Security
SECRET_KEY=change-me-in-production-use-a-long-random-string

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

OPENAI_API_KEY=abcdefg

# Mailer
SENDGRID_API_KEY=
MAILER_ENABLED=false
LOG_AUTH_CODES=true

# Billing / Lemon Squeezy
BILLING_ENABLED=false
BILLING_MANUAL_SECRET=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_MICRO=
LEMONSQUEEZY_VARIANT_PLUS=
LEMONSQUEEZY_VARIANT_PRO=

# Support / Zoho Desk (server-side ticket creation via OAuth2)
# Data-center bases: US https://desk.zoho.com + https://accounts.zoho.com;
# EU .eu, IN .in, AU .com.au. Generate client id/secret + refresh token at
# https://api-console.zoho.com (scope: Desk.tickets.CREATE,Desk.tickets.READ).
# Leave the OAuth values empty to disable support (endpoint returns 503).
ZOHODESK_API_BASE=https://desk.zoho.com
ZOHODESK_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHODESK_ORG_ID=
ZOHODESK_CLIENT_ID=
ZOHODESK_CLIENT_SECRET=
ZOHODESK_REFRESH_TOKEN=
ZOHODESK_DEPARTMENT_ID=

# S3 compatible storage
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_BUCKET=product-pictures
STORAGE_ACCESS_KEY=mi_precio_local
STORAGE_SECRET_KEY=mi_precio_local_secret

# Web Push (PWA notifications)
# Generate a key pair with: pipenv run python bin/generate_vapid_keys.py
# Leave empty to disable push (the app still works, just no notifications).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@miprecio.app
